import { NextRequest, NextResponse } from 'next/server'
import Anthropic from '@anthropic-ai/sdk'

export const maxDuration = 60

const client = new Anthropic({ apiKey: process.env.ANTHROPIC_API_KEY })

export async function POST(req: NextRequest) {
  try {
    const body = await req.json()
    const fundName = String(body.fundName || '')
    const response = await (client.messages.create as any)({
      model: 'claude-opus-4-8',
      max_tokens: 500,
      tools: [{ type: 'web_search_20250305', name: 'web_search' }],
      messages: [{ role: 'user', content: 'Trouve ISIN, gestionnaire, categorie pour: ' + fundName + '. JSON sans backticks: {"isin":"CODE","manager":"NOM","category":"Actions","notes":"description"}' }],
    })
    let text = ''
    for (const block of response.content) {
      if ((block as any).type === 'text') text += (block as any).text
    }
    const start = text.indexOf('{')
    const end = text.lastIndexOf('}')
    if (start === -1 || end === -1) return NextResponse.json({ error: 'Pas de JSON' }, { status: 500 })
    return NextResponse.json(JSON.parse(text.slice(start, end + 1)))
  } catch (err: any) {
    return NextResponse.json({ error: err.message }, { status: 500 })
  }
}
